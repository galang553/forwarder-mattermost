# Host port mapping for the forwarder service
PORT=8080

# Your Mattermost Server URL
MATTERMOST_URL=http://your-mattermost-ip:8065

# The Bot Access Token created in Mattermost (Integrations -> Bot Accounts)
MATTERMOST_BOT_TOKEN=your_mattermost_bot_token

# The Slash Command Token created in Mattermost (Integrations -> Slash Commands) (Optional)
SLASH_COMMAND_TOKEN=your_slash_command_token

# The external URL where this forwarder service is reachable by Mattermost
SERVER_URL=http://your-server-ip:8080

# Database connection settings (required for Direct Message / Private Channel bypassing)
DB_HOST=db
DB_PORT=5432
DB_USER=mmuser
DB_PASSWORD=your_db_password
DB_NAME=mattermost
